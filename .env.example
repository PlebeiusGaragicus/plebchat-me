# Copy to .env (gitignored) to pre-fill the AI/search settings forms in dev.
# The hosted build ships without these — users bring their own keys via the
# in-app Settings dialogs, stored in localStorage only.

# AI endpoint (Read chat + Search agent)
VITE_AI_BASE_URL=              # e.g. https://openrouter.ai/api/v1 or http://localhost:1234/v1
VITE_AI_API_KEY=               # e.g. sk-or-...
VITE_AI_MODEL=                 # e.g. anthropic/claude-sonnet-5
VITE_AI_API=                   # openai-completions (default) or anthropic-messages

# Search mode web tools
VITE_FIRECRAWL_API_KEY=        # fc-... from https://firecrawl.dev
